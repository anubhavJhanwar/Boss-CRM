# Server Configuration
PORT=5000
NODE_ENV=development

# Firebase Admin SDK Configuration
# Option 1 (Local Development): Download your Firebase service account key JSON file from:
# Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Save it as 'firebase-service-account.json' in the backend folder
# NEVER commit this file to Git!
#
# Option 2 (Render Deployment): Copy the entire content of firebase-service-account.json
# and paste it as a single-line JSON string in FIREBASE_SERVICE_ACCOUNT_KEY
# Example: FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=

# Admin Email for Notifications
ADMIN_EMAIL=your-email@example.com

# Email Service Configuration (Gmail SMTP)
# Generate an App Password from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# CORS Origin (use * for development, specific domain for production)
CORS_ORIGIN=*

# Firebase Project Configuration
# Get these from Firebase Console > Project Settings > General > Your apps
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
